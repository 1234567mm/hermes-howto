{
  "name": "github-readonly",
  "description": "GitHub integration for repository exploration (read-only)",
  "servers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": {
          "type": "env",
          "name": "GITHUB_TOKEN"
        }
      },
      "filter": {
        "tools": {
          "include": [
            "github_get_file",
            "github_search_issues",
            "github_search_repositories",
            "github_list_issues",
            "github_get_issue",
            "github_list_pulls",
            "github_get_pull_request",
            "github_list_commits"
          ]
        }
      }
    }
  }
}

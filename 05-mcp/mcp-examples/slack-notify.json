{
  "name": "slack-notify",
  "description": "Slack integration for sending notifications",
  "servers": {
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": {
          "type": "env",
          "name": "SLACK_BOT_TOKEN"
        },
        "SLACK_TEAM_ID": {
          "type": "env",
          "name": "SLACK_TEAM_ID"
        }
      }
    }
  }
}
